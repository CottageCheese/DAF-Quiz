                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Top Quizzes",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/leaderboard/top-quizzes?count=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaderboard", "top-quizzes"],
              "query": [{ "key": "count", "value": "10" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Is array', () => pm.expect(j).to.be.an('array'));",
                  "pm.test('Count <= 10', () => pm.expect(j.length).to.be.at.most(10));",
                  "if (j.length > 0) {",
                  "  pm.test('First rank is 1', () => pm.expect(j[0].rank).to.equal(1));",
                  "  pm.test('Quiz title present', () => pm.expect(j[0].quizTitle).to.be.a('string').and.not.empty);",
                  "}"
                ]
              }
            }
          ]
