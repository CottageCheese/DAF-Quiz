                  "if (j.length > 0) {",
                  "  pm.test('First rank is 1', () => pm.expect(j[0].rank).to.equal(1));",
                  "  pm.test('BestScorePercent in range', () => {",
                  "    pm.expect(j[0].bestScorePercent).to.be.at.least(0);",
                  "    pm.expect(j[0].bestScorePercent).to.be.at.most(100);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
