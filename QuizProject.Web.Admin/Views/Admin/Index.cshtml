@model PagedResult<AdminQuizListViewModel>
@{
    ViewData["Title"] = "Admin — Quiz Management";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h1 class="h3 mb-0">Quiz Management</h1>
    <a asp-action="Create" class="btn btn-dark">+ New Quiz</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">No quizzes yet. Create one to get started.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th class="d-none d-sm-table-cell">Questions</th>
                <th class="d-none d-md-table-cell">Created By</th>
                <th class="d-none d-md-table-cell">Created</th>
                <th class="d-none d-lg-table-cell">Publish Date</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var quiz in Model.Items)
            {
                <tr>
                    <td>
                        <strong>@quiz.Title</strong>
                        @if (!string.IsNullOrEmpty(quiz.Description))
                        {
                            <br/>
                            <small class="text-muted">@quiz.Description</small>
                        }
                    </td>
                    <td class="d-none d-sm-table-cell">@quiz.QuestionCount</td>
                    <td class="d-none d-md-table-cell">@(quiz.CreatedByEmail ?? "—")</td>
                    <td class="d-none d-md-table-cell">@quiz.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td class="d-none d-lg-table-cell">
                        @if (quiz.PublishedAt.HasValue)
                        {
                            @quiz.PublishedAt.Value.ToString("dd MMM yyyy HH:mm")
                            <span class="text-muted">UTC</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Not set</span>
                        }
                    </td>
                    <td>
                        @if (quiz.IsPublished)
                        {
                            <span class="badge bg-success">Published</span>
                        }
                        else if (quiz.PublishedAt.HasValue)
                        {
                            <span class="badge bg-warning text-dark">Scheduled</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex flex-wrap justify-content-end gap-1">
                            <a asp-action="Details" asp-route-id="@quiz.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@quiz.Id"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="DeleteQuiz" method="post"
                                  onsubmit="return confirm('Delete quiz \'@quiz.Title\'? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@quiz.Id"/>
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Quiz list pagination">
            <ul class="pagination justify-content-center">
                @if (Model.Page > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>
                }
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                @if (Model.Page < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
        <p class="text-center text-muted small">
            Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount quizzes
        </p>
    }
}
