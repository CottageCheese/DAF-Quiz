@model QuizProject.Web.Models.ViewModels.EditQuizFormModel
@{
    ViewData["Title"] = "Edit Quiz";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="h3 mb-4">Edit Quiz</h1>

        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id"/>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" autofocus aria-required="true"/>
                        <span asp-validation-for="Title" class="text-danger small" role="alert" aria-live="polite"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small" role="alert" aria-live="polite"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PublishedAt" class="form-label fw-semibold"></label>
                        <input asp-for="PublishedAt" type="datetime-local" class="form-control"
                               value="@(Model.PublishedAt.HasValue ? Model.PublishedAt.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                               aria-describedby="publishedat-hint"/>
                        <div id="publishedat-hint" class="form-text">
                            Leave blank to keep as a draft. Set to a future date/time (UTC) to schedule publication.
                            Set to now or a past date/time to publish immediately.
                        </div>
                        <span asp-validation-for="PublishedAt" class="text-danger small" role="alert" aria-live="polite"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
