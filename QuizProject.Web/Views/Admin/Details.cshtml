@model AdminQuizDetailViewModel
@{
    ViewData["Title"] = $"Quiz: {Model.Title}";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted mb-1">@Model.Description</p>
        }
        <small class="text-muted">
            Created by @(Model.CreatedByEmail ?? "Unknown") on @Model.CreatedAt.ToString("dd MMM yyyy HH:mm") UTC
            &nbsp;|&nbsp;
            @if (Model.IsPublished)
            {
                <span class="badge bg-success">Published</span>
                @: since @Model.PublishedAt!.Value.ToString("dd MMM yyyy HH:mm") <span class="text-muted">UTC</span>
            }
            else if (Model.PublishedAt.HasValue)
            {
                <span class="badge bg-warning text-dark">Scheduled</span>
                @: for @Model.PublishedAt.Value.ToString("dd MMM yyyy HH:mm") <span class="text-muted">UTC</span>
            }
            else
            {
                <span class="badge bg-secondary">Draft — not yet published</span>
            }
        </small>
    </div>
    <div class="d-flex gap-2 flex-shrink-0">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit Quiz</a>
        <a asp-action="AddQuestion" asp-route-quizId="@Model.Id" class="btn btn-primary btn-sm">+ Add Question</a>
        <a asp-action="Index" class="btn btn-outline-dark btn-sm">Back to list</a>
    </div>
</div>

@if (!Model.Questions.Any())
{
    <div class="alert alert-info">
        No questions yet. Use the <strong>+ Add Question</strong> button to add some.
    </div>
}
else
{
    <div class="accordion" id="questionsAccordion">
        @foreach (var question in Model.Questions.OrderBy(q => q.DisplayOrder))
        {
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading-@question.Id">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse-@question.Id"
                            aria-expanded="false"
                            aria-controls="collapse-@question.Id">
                        <span class="badge bg-secondary me-2">#@question.DisplayOrder</span>
                        @question.Text
                    </button>
                </h2>
                <div id="collapse-@question.Id" class="accordion-collapse collapse"
                     aria-labelledby="heading-@question.Id">
                    <div class="accordion-body">
                        <ul class="list-group mb-3">
                            @foreach (var answer in question.Answers)
                            {
                                <li class="list-group-item @(answer.IsCorrect ? "list-group-item-success" : "")">
                                    @if (answer.IsCorrect)
                                    {
                                        <strong>&#10003; @answer.Text</strong>
                                        <span class="badge bg-success ms-2">Correct</span>
                                    }
                                    else
                                    {
                                        @answer.Text
                                    }
                                </li>
                            }
                        </ul>
                        <div class="d-flex gap-2">
                            <a asp-action="EditQuestion"
                               asp-route-quizId="@Model.Id"
                               asp-route-questionId="@question.Id"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form asp-action="DeleteQuestion" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this question?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="quizId" value="@Model.Id"/>
                                <input type="hidden" name="questionId" value="@question.Id"/>
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
