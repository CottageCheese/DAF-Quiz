@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <section aria-labelledby="login-heading">
            <h1 id="login-heading" class="mb-4">Sign in</h1>

            <form asp-action="Login" method="post" novalidate>
                <input type="hidden" value="@ViewData["ReturnUrl"]" name="returnUrl" />
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" aria-live="assertive"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email"
                           class="form-control"
                           autocomplete="email"
                           aria-required="true" />
                    <span asp-validation-for="Email" class="text-danger" role="alert" aria-live="polite"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password"
                           class="form-control"
                           autocomplete="current-password"
                           aria-required="true" />
                    <span asp-validation-for="Password" class="text-danger" role="alert" aria-live="polite"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">Sign in</button>

                <p class="text-center">
                    No account? <a asp-controller="Account" asp-action="Register">Create one</a>
                </p>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
